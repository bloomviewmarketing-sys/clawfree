{
  "name": "clawfree",
  "version": "0.1.0",
  "description": "ClawFree — Open-source AI agent platform powered by Claude CLI",
  "type": "module",
  "bin": { "clawfree": "dist/index.js" },
  "main": "dist/index.js",
  "files": ["dist/"],
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@clawfree/shared": "workspace:*",
    "@clawfree/gateway": "workspace:*",
    "@clack/prompts": "^0.7.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/websocket": "^10.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "croner": "^8.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "ora": "^8.0.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0",
    "@types/node": "^20.14.0"
  },
  "keywords": ["ai", "agent", "claude", "cli", "automation"],
  "license": "MIT"
}
